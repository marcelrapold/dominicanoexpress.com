{
  "name": "dominicanoexpress",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:box": "esbuild apps/web/js/box-illustration-src.mjs --bundle --format=esm --outfile=apps/web/js/box-illustration.js --platform=browser",
    "build:scan": "esbuild apps/web/js/scan-src/index.mjs --bundle --format=iife --outfile=apps/web/js/scan-profiles.js --platform=browser",
    "build:i18n": "node scripts/extract-scan-i18n.mjs",
    "build": "npm run build:i18n && npm run build:box && npm run build:scan"
  },
  "dependencies": {
    "@vercel/og": "^0.6.3",
    "resend": "^4.8.0"
  },
  "devDependencies": {
    "@elchininet/isometric": "^4.0.0",
    "esbuild": "^0.28.0"
  }
}
