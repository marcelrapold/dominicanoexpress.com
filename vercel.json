{
  "routes": [
    { "src": "/scan/?$",               "dest": "/apps/scan/index.html" },
    { "src": "/scan/(.*)",             "dest": "/apps/scan/$1" },
    { "src": "/og-image\\.png",        "dest": "/api/og" },
    { "src": "/flags/(.*)",            "dest": "/apps/web/flags/$1" },
    { "src": "/logo\\.svg",            "dest": "/apps/web/logo.svg" },
    { "src": "/logo-white\\.svg",      "dest": "/apps/web/logo-white.svg" },
    { "src": "/site\\.webmanifest",    "dest": "/apps/web/site.webmanifest" },
    { "src": "/apple-touch-icon\\.png","dest": "/apps/web/logo.svg" },
    { "src": "/impressum/?$",          "dest": "/apps/web/impressum.html" },
    { "src": "/datenschutz/?$",        "dest": "/apps/web/datenschutz.html" },
    { "src": "/agb/?$",                "dest": "/apps/web/agb.html" },
    {
      "src": "/(.*)",
      "dest": "/apps/web/index.html",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "SAMEORIGIN",
        "X-XSS-Protection": "1; mode=block",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=()"
      }
    }
  ]
}
